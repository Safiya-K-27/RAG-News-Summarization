# Data ingestion
USE_HF_DATASETS=false
KAGGLE_NEWS_CSV_PATH=
MAX_DOCS_PER_SOURCE=50

# Full training mode
RUN_TRAINING=false
TRAIN_SAMPLE_LIMIT=4000
DOMAIN_SAMPLE_LIMIT=1200
RETRIEVER_TRAIN_EPOCHS=1
SUMMARIZER_TRAIN_EPOCHS=1
TRAIN_BATCH_SIZE=8
SUMMARIZER_MAX_INPUT_LENGTH=512
SUMMARIZER_MAX_TARGET_LENGTH=96
TRAINING_OUTPUT_DIR=checkpoints
BASE_SUMMARIZER_TRAIN_MODEL=google/flan-t5-small

# NLP models
SPACY_MODEL=en_core_web_sm
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
TOP_K_RETRIEVAL=8

# LLM provider: openai or hf
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
HF_SUMMARY_MODEL=facebook/bart-large-cnn

# Personalization defaults
DEFAULT_SUMMARY_LENGTH=medium
DEFAULT_SUMMARY_TONE=formal
DEFAULT_BIAS_CONTROL=balanced
DEFAULT_READING_LEVEL=medium
DEFAULT_NEWS_TOPIC=latest entertainment industry announcements and partnerships
